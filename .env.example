# LLM 配置（OpenAI 兼容）
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
# 全局最大并发 LLM 调用数（建议 ≈ JOB_CONCURRENCY * 单 job 内并发 LLM 数）
LLM_MAX_CONCURRENCY=6

# 鉴权
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168
ADMIN_TOKEN=change-me-to-a-long-random-admin-token

# 服务
APP_HOST=0.0.0.0
APP_PORT=8000
# 本地开发可用 SQLite；线上用 PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
# 线上示例：
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATA_DIR=./data/generated

# 浏览器（Playwright）最大并发实例数，每个实例约占用几百 MB 内存
BROWSER_MAX_CONCURRENCY=3

# Job 级并发：同一时刻最多跑几个 job（每个 job 内部已经并发生成多份软件）
JOB_CONCURRENCY=2
